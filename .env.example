# NextPick 환경변수 템플릿
# 실제 키는 이 파일이 아니라 .env.local 에 넣으세요. (이 파일은 git에 커밋됩니다 — 비밀값 금지)

# YouTube Data API v3 키 — https://console.cloud.google.com 에서 발급 (YouTube Data API v3 활성화 필요)
YOUTUBE_API_KEY=

# 분석할 내 채널 핸들 (예: @MrBeast)
YOUTUBE_CHANNEL_HANDLE=@yourhandle

# 트렌드 조회 지역 코드 (한국=KR)
YOUTUBE_REGION_CODE=KR
